###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_a_32_char_random_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# SQLite — aucune installation de serveur requise.
# Le fichier var/app.db est créé automatiquement lors de la première migration.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/app.db"

# Exemples pour d'autres bases :
# DATABASE_URL="mysql://user:password@127.0.0.1:3306/task_api?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/task_api?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###
